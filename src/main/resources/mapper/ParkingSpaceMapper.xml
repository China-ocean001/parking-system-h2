<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.parking.mapper.ParkingSpaceMapper">
    <select id="findAll" resultType="com.parking.entity.ParkingSpace">
        SELECT * FROM parking_space ORDER BY space_number
    </select>
    <select id="findById" resultType="com.parking.entity.ParkingSpace">
        SELECT * FROM parking_space WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.parking.entity.ParkingSpace">
        INSERT INTO parking_space (space_number, status, remark) VALUES (#{spaceNumber}, #{status}, #{remark})
    </insert>
    <update id="updateStatus" parameterType="com.parking.entity.ParkingSpace">
        UPDATE parking_space SET status = #{status} WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM parking_space WHERE id = #{id}
    </delete>
</mapper>
