<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.parking.mapper.UserMapper">
    <select id="findByUsername" resultType="com.parking.entity.User">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>
    <insert id="insert" parameterType="com.parking.entity.User">
        INSERT INTO sys_user (username, password, role) VALUES (#{username}, #{password}, #{role})
    </insert>
    <select id="findAll" resultType="com.parking.entity.User">
        SELECT * FROM sys_user
    </select>
    <delete id="deleteById">
        DELETE FROM sys_user WHERE id = #{id}
    </delete>
</mapper>
